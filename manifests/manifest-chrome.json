{
  "manifest_version": 3,
  "name": "Vault",
  "default_locale": "en",
  "description": "A Chrome extension for managing and searching secrets in Hashicorp Vault",
  "version": "2.0.0",
  "action": {
    "default_icon": "icons/logo128.png",
    "default_popup": "html/navigate.html",
    "default_title": "Vault"
  },
  "icons": {
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Open Vault popup"
    }
  },
  "background":{
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "idle",
    "alarms",
    "scripting"
  ],
  "host_permissions" : [
    "http://*/*",
    "https://*/*"
  ]

}
